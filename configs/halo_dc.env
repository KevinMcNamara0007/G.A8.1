# ═══════════════════════════════════════════════════════════
#  M1 — Halo DC Overlay
#
#  Full G.A8.1 stack inside one trust boundary.
#  No subspace privacy claims exercised.
#  Layered on top of ../config.env when A81_MODALITY=halo_dc.
# ═══════════════════════════════════════════════════════════

A81_MODALITY=halo_dc
A81_ROLE=hybrid

# Codebook + indices live with the running pipeline.
A81_CODEBOOK_LOCATION=local
A81_INDICES_LOCATION=local

# No bundle, no remote transport, no LLM bridge.
A81_BUNDLE_PATH=
A81_REMOTE_URL=

# Subspace privacy defenses are inert here (single trust domain), but
# leave them on so a misconfigured deploy still gets the protection
# rather than silently downgrading.
A81_BASIS_ROTATION=true
A81_BLINDING=true

# KMS optional in this modality. Customer DC may still want HSM-rooted
# at-rest encryption keys; default 'none' for a clean dev experience.
A81_KMS_PROVIDER=none

A81_LLM_PROVIDER=none
