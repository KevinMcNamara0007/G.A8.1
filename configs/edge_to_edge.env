# ═══════════════════════════════════════════════════════════
#  M4 — Edge↔Edge Overlay (SCAFFOLD)
#
#  End-to-end ternary computation. Edge encodes EH VSAs, transmits over
#  TLS to a ternary-native LLM (BitNet 2.5 on EH VSAs) running on
#  commodity / public / community-operated infrastructure, decodes
#  responses through the edge codebook.
#
#  This overlay is config-only at this stage. The validation track
#  (T5 distilled on EH VSAs) and the production track (BitNet 2.5)
#  are not yet wired. A81_LLM_PROVIDER=none is the only supported
#  value today; any other value will fail assert_ready_for(M4).
#
#  Layered on top of ../config.env when A81_MODALITY=edge_to_edge.
# ═══════════════════════════════════════════════════════════

A81_MODALITY=edge_to_edge
A81_ROLE=edge

# Codebook MUST stay at edge — same constraint as M3.
A81_CODEBOOK_LOCATION=edge
A81_INDICES_LOCATION=edge

A81_BUNDLE_PATH=

# Transport — required, identical posture to M3.
A81_REMOTE_URL=                   # REQUIRED — https://… of remote BitNet/T5 endpoint
A81_TLS_MIN=1.3
A81_TLS_PQ_HYBRID=true
A81_TLS_CERT_PIN=

# Subspace privacy inherits all M3 protections.
A81_BASIS_ROTATION=true
A81_BASIS_WINDOW_SECONDS=3600
A81_BASIS_OVERLAP=0.10
A81_BLINDING=true
A81_BLINDING_KEY_REF=

# KMS — default 'none' so dev/test loads without extra config.
# Production REQUIRES A81_KMS_PROVIDER=qkey.
A81_KMS_PROVIDER=none
A81_KMS_LOCAL_DIR=
A81_QKEY_URL=
A81_QKEY_ACCESS_KEY_FILE=
A81_QKEY_MODE=omega

# LLM bridge — scaffold.
#   Phase 0 — frozen BitNet 2.5 + learned bridge projection (whitepaper §7.2)
#   Phase 1 — BitNet 2.5 trained from scratch on EH VSAs
#   Phase 2 — BitNet 2.5 with embedding layer stripped, native VSA throughout
#   Validation — T5 baseline on EH VSAs, distilled from text-T5 teacher
A81_LLM_PROVIDER=none             # none | t5_validation | bitnet25 — only 'none' supported today
A81_LLM_ENDPOINT=
A81_LLM_ATTESTATION_REQUIRED=true # See §7.3: model integrity via attestation
