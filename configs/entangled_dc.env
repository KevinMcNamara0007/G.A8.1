# ═══════════════════════════════════════════════════════════
#  M3 — Entangled DC Overlay
#
#  First modality where the subspace privacy claim is exercised.
#  Codebook + indices stay at edge under customer trust.
#  Ternary VSAs travel over TLS 1.3 to a remote similarity processor
#  that runs on commodity / sovereign cloud or partner infrastructure.
#
#  Two roles share this overlay:
#    A81_ROLE=edge              — encodes, holds codebook, decodes results
#    A81_ROLE=remote_processor  — stateless BSC similarity service
#  Set the role explicitly per deployment.
#
#  Layered on top of ../config.env when A81_MODALITY=entangled_dc.
# ═══════════════════════════════════════════════════════════

A81_MODALITY=entangled_dc
A81_ROLE=edge                     # override on the remote side: remote_processor

# CRITICAL: codebook MUST stay at edge. Anything else collapses the privacy claim.
A81_CODEBOOK_LOCATION=edge
A81_INDICES_LOCATION=edge

# No bundle in this modality.
A81_BUNDLE_PATH=

# Transport — required when ROLE=edge.
A81_REMOTE_URL=                   # REQUIRED on edge — https://… of remote processor
A81_TLS_MIN=1.3                   # Hard floor; whitepaper §8.1 rejects 1.2.
A81_TLS_PQ_HYBRID=true            # X25519 + ML-KEM where remote supports it
A81_TLS_CERT_PIN=                 # STRONGLY recommended — pin the remote SPKI hash

# Subspace privacy — required.
A81_BASIS_ROTATION=true
A81_BASIS_WINDOW_SECONDS=3600     # Tune per query volume × threat model (§8.3)
A81_BASIS_OVERLAP=0.10
A81_BLINDING=true
A81_BLINDING_KEY_REF=             # KMS-protected; required for production deployments

# KMS — default 'none' so dev/test loads without extra config.
# Production REQUIRES A81_KMS_PROVIDER=qkey so blinding seeds and TLS
# material are rooted in the OneShot/qkey appliance rather than in
# process memory.
A81_KMS_PROVIDER=none
A81_KMS_LOCAL_DIR=
A81_QKEY_URL=
A81_QKEY_ACCESS_KEY_FILE=
A81_QKEY_MODE=omega

A81_LLM_PROVIDER=none
