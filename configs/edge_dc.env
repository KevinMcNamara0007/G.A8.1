# ═══════════════════════════════════════════════════════════
#  M2 — Edge DC Overlay
#
#  Encoder runs in central DC; signed bundle ships to one or more
#  edge devices that run inference locally.
#
#  Two roles share this overlay:
#    A81_ROLE=encoder     — central pipeline that produces bundles
#    A81_ROLE=edge        — edge runtime that imports + queries
#  Set the role explicitly per deployment.
#
#  Layered on top of ../config.env when A81_MODALITY=edge_dc.
# ═══════════════════════════════════════════════════════════

A81_MODALITY=edge_dc
A81_ROLE=hybrid                   # override per deployment: encoder | edge

# Codebook follows the bundle. After import, codebook + indices live at edge.
A81_CODEBOOK_LOCATION=edge
A81_INDICES_LOCATION=edge

# Bundle protocol — required.
# Encoder writes; edge reads.
A81_BUNDLE_PATH=                  # REQUIRED — set per deployment
A81_BUNDLE_SIGNING_KEY_REF=       # REQUIRED on encoder
A81_BUNDLE_ENC_KEY_REF=           # Optional; recommended for non-air-gapped transport
A81_BUNDLE_DELTA_BASE=            # Manifest version for incremental updates
A81_BUNDLE_VERIFY_ON_LOAD=true

# No remote inference path.
A81_REMOTE_URL=

# Subspace privacy not exercised (edge holds the codebook), but rotate
# anyway so that bundle replay across rotation windows is bounded.
A81_BASIS_ROTATION=true
A81_BLINDING=false

# KMS — default 'none' so dev/test loads without extra config.
# Production REQUIRES A81_KMS_PROVIDER=qkey with a live OneShot/qkey
# endpoint and access key, since bundle signing/encryption needs a
# hardware-rooted key.
A81_KMS_PROVIDER=none
A81_KMS_LOCAL_DIR=
A81_QKEY_URL=
A81_QKEY_ACCESS_KEY_FILE=
A81_QKEY_MODE=omega

A81_LLM_PROVIDER=none
