# ═══════════════════════════════════════════════════════════
#  G.A8.1 Configuration — Base Substrate
#
#  Layout:
#    config.env                        ← this file (substrate, common to all modalities)
#    configs/halo_dc.env               ← M1 overlay
#    configs/edge_dc.env               ← M2 overlay
#    configs/entangled_dc.env          ← M3 overlay
#    configs/edge_to_edge.env          ← M4 overlay (scaffold)
#
#  Resolution order (later wins):
#    base config.env  →  configs/<A81_MODALITY>.env  →  process environment
#
#  Usage:
#    source config.env && python3 encode/encode.py ...
#    A81_MODALITY=entangled_dc python3 encode/encode.py ...
# ═══════════════════════════════════════════════════════════

# ── Modality Selector ────────────────────────────────────
# Internet Subspace modality for this process. Drives overlay loading
# in config.py and gates required-key validation per modality.
#   halo_dc       — M1: full G.A8.1 stack in one trust domain (DC or laptop)
#   edge_dc       — M2: encode central, transfer signed bundle to edge, infer at edge
#   entangled_dc  — M3: codebook+indices at edge, ternary VSAs processed remote
#   edge_to_edge  — M4: ternary-native LLM (BitNet 2.5) on public infra (scaffold)
A81_MODALITY=halo_dc

# Process role within the modality. Encode/edge/remote_processor are split
# roles (used by edge_dc + entangled_dc); hybrid is a single-process role
# that fills all responsibilities (the default for halo_dc).
#   encoder | edge | remote_processor | hybrid
A81_ROLE=hybrid

# ── Vector Space ─────────────────────────────────────────
A81_DIM=16384                     # BSC vector dimensionality
A81_K=128                         # Sparsity (active indices per vector, √dim)
A81_SEED=42                       # Codebook seed (deterministic encoding)
A81_MAX_SALIENT_TOKENS=12         # Token budget per vector (√k)

# ── Sharding ─────────────────────────────────────────────
A81_ENTITY_BUCKETS=4              # Level 1: entity hash buckets
A81_ACTION_CLUSTERS=20            # Level 2: action clusters (discovered)
A81_CLUSTER_SAMPLE=100000         # Records to sample for cluster discovery
A81_WAVES=4                       # Encoding wave parallelism (0 = auto via CPU_FRACTION)

# ── Parallelism / CPU ────────────────────────────────────
A81_CPU_FRACTION=0.8              # Auto-parallelism cap: fraction of cores used
                                  #  when WAVES or --threads is unset or 0.
                                  #  Leaves headroom for main thread, GIL, OS.
                                  #  On a 10-core box, 0.8 → 8 workers.

# ── LSH Index ────────────────────────────────────────────
A81_LSH_TABLES=8                  # Number of LSH hash tables
A81_LSH_HASH_SIZE=16              # Bits per hash
A81_LSH_MULTIPROBE=true           # Enable multi-probe LSH

# ── Query ────────────────────────────────────────────────
A81_QUERY_SHARDS=3                # Number of shards to search per query
A81_QUERY_TOP_K=10                # Default results per query
A81_QUERY_FETCH_MULTIPLIER=5      # Over-fetch factor (k × N candidates)

# ── Scoring Weights ──────────────────────────────────────
A81_WEIGHT_BSC=50                 # BSC vector similarity weight (0-100)
A81_WEIGHT_KEYWORD=40             # Keyword overlap weight (0-100)
A81_WEIGHT_PROXIMITY=10           # Adjacent term proximity weight (0-100)

# ── Gazetteer ────────────────────────────────────────────
A81_GAZETTEER_BOOST=3.0           # Boost multiplier for gazetteer terms in IDF
A81_GAZETTEER_GUARANTEED=true     # Reserve slots for gazetteer terms in top-k

# ── Adaptive Learning ────────────────────────────────────
A81_ADAPTIVE_GAZ=0                # 0=disabled, 1=enabled (Hebbian+Ebbinghaus)
A81_ADAPTIVE_MIN_SCORE=0.15       # Minimum result score to learn from
A81_ADAPTIVE_MAX_EXPANSIONS=5     # Max learned expansions per root term
A81_ADAPTIVE_RETENTION=0.1        # Ebbinghaus retention threshold for pruning

# ── Corpus Profiler v13.1 (PlanC) ────────────────────────
A81_DIMENSIONS_PROFILE_REQUIRED=true  # Abort encode if no profile found
A81_DIMENSIONS_HEADROOM=1.2           # v13.1.3: plateau-aware context.
                                      #  In Zone 2 (plateau), the smallest-D floor is
                                      #  aggressive; headroom promotes to a grid D that is
                                      #  still IN the plateau — measurement-supported.
                                      #  1.2 = lean slightly toward the middle of the plateau.
                                      #  Set 1.0 to pick the minimum-memory floor exactly.
A81_DIMENSIONS_TRIVIAL_THRESHOLD=10000  # Corpora smaller than this use cfg defaults
A81_DIMENSIONS_GRID_EXTENDED=false    # Adds 6144/12288 to the grid. GATED on EHC C++
                                      #  review — non-power-of-2 D may break BSC kernels.
                                      #  See PlanC_cpp_engineer_memo.md.
A81_DIMENSIONS_PROFILE_SAMPLE=10000   # Stage-2 stratified sample floor (scales to 0.5% of corpus, cap 50K)
A81_DIMENSIONS_PROFILE_QUERIES=200    # Stage-2 held-out query count
A81_DIMENSIONS_LEGACY_SENTINEL=v13.0-default  # Grandfather value for pre-v13.1 shards

# ── Media Encoding ───────────────────────────────────────
A81_MEDIA_ENABLED=true            # Encode images/videos into separate index
A81_VISION_SEED=2100              # VisionEncoder seed
A81_VIDEO_SEED=2300               # VideoEncoder seed
A81_VIDEO_FRAMES=8                # Frames to sample from video

# ── Selective Attention ──────────────────────────────────
A81_ATTENTION_BETA=1.5            # Attention boost factor
A81_ATTENTION_MIN_SCORE=0.0       # Minimum score for attention filtering

# ── Codebook & Indices Location ──────────────────────────
# Where the codebook and inverted indices physically reside.
# In halo_dc both are local to the running process.
# In edge_dc both move to the edge after bundle import.
# In entangled_dc / edge_to_edge they MUST stay at edge (subspace privacy
# claim collapses if the codebook leaves customer trust boundary).
#   local | edge | sealed_omega
A81_CODEBOOK_LOCATION=local
A81_INDICES_LOCATION=local

# ── Bundle (M2 — Edge DC) ────────────────────────────────
# Snapshot/transfer protocol artifacts. Encoder writes; edge reads.
# Bundle = signed, optionally encrypted archive of:
#   { codebook, BSCCompactIndex, BSCLSHIndex, encoded shards,
#     corpus_profile.json, manifest.json }
# Required when MODALITY=edge_dc.
A81_BUNDLE_PATH=                  # Filesystem or s3:// URI for snapshot output/input
A81_BUNDLE_SIGNING_KEY_REF=       # KMS key reference (see KMS section); required on encoder
A81_BUNDLE_ENC_KEY_REF=           # KMS key reference; empty disables payload encryption
A81_BUNDLE_DELTA_BASE=            # Manifest version of previous bundle for incremental delta
A81_BUNDLE_VERIFY_ON_LOAD=true    # Edge: refuse to load bundles with bad signature
A81_BUNDLE_INCLUDE_PROFILE=true   # Refuse to export/import a bundle without corpus_profile.json
                                  #  Edge cannot re-profile (no corpus on edge), so the profile
                                  #  must travel with the bundle or D/k is unknown at query time.

# ── Transport / Channel privacy (M3, M4) ─────────────────
# Edge → remote processor (entangled_dc) or remote LLM (edge_to_edge).
# Channel privacy is delegated to OS primitives — sshd or libssl —
# rather than reimplemented in the app. Pick one:
#   ssh-tunnel    — DEFAULT. Client opens a long-lived SSH local-forward
#                   to the processor (see tunnel_to_processor.sh) and
#                   the EdgeClient connects to 127.0.0.1:NNNN over plain
#                   HTTP inside the tunnel. sshd handles KEX, AEAD,
#                   integrity, and host-key authentication. No app-level
#                   TLS code path runs in this mode.
#   http-loopback — SSH-tunnel without the SSH part: connect to localhost
#                   over plain HTTP. ONLY for in-process tests / dev.
#                   Will refuse non-loopback URLs.
#   https         — Direct HTTPS, when SSH-tunnel isn't applicable
#                   (e.g., processor behind a vendor LB that won't allow
#                   tunnels). Activates the TLS 1.3 / cert pin code path.
A81_REMOTE_TRANSPORT=ssh-tunnel
A81_REMOTE_URL=                   # ssh-tunnel:    http://127.0.0.1:<local-port>
                                  # http-loopback: http://127.0.0.1:<port>
                                  # https:         https://host[:port]/

# TLS settings — used ONLY when A81_REMOTE_TRANSPORT=https.
# Inactive (no-op) for ssh-tunnel and http-loopback transports.
A81_TLS_MIN=1.3                   # Minimum TLS version. DO NOT lower; whitepaper §8.1 rejects 1.2.
A81_TLS_PQ_HYBRID=true            # Hybrid X25519+ML-KEM where remote supports it
A81_TLS_CERT_PIN=                 # SPKI hash of expected remote cert; empty disables pinning
A81_TLS_CIPHERSUITES=TLS_AES_256_GCM_SHA384,TLS_CHACHA20_POLY1305_SHA256

# ── Subspace Statistical Hardening (M3, M4) ──────────────
# These are SEPARATE from channel privacy and SEPARATE from structural
# subspace privacy:
#   - Channel privacy: SSH/HTTPS at the OS layer (above).
#   - Structural subspace privacy: codebook physically can't be on the
#     processor → automatic, no flag.
#   - Statistical hardening (this section): defends against a long-running
#     adversary who watches many queries and tries to reverse-engineer the
#     codebook from accumulated projections. See whitepaper §8.3, §8.4.
#
# Config-validated today; not yet applied to the wire. Crypto-review
# pass required before these can be relied on for production privacy
# claims beyond the structural guarantee.
A81_BASIS_ROTATION=true           # Sliding-window basis rotation (vs. accumulation attacks)
A81_BASIS_WINDOW_SECONDS=3600     # Rotation cadence; tune per query volume × threat model
A81_BASIS_OVERLAP=0.10            # Fractional basis overlap between consecutive windows
A81_BLINDING=true                 # Per-query ternary mask blinding within a window
A81_BLINDING_KEY_REF=             # KMS reference for blinding seed material (empty → session-derived)

# Remote-side profile pinning (M3, M4). When enabled, the remote processor
# records (D, k, source_hash) from the first query of a session and rejects
# subsequent queries that diverge — protects against profile-mismatch
# scenarios where a misconfigured client encodes against a different basis.
#   off      — no pin (dev only)
#   session  — pin per-session, expire when session ends
#   strict   — pin globally, refuse new sessions with different D/k
A81_REMOTE_PROFILE_PIN=session

# ── KMS (active providers) ───────────────────────────────
# Pluggable provider. Default 'none' so dev/test loads cleanly.
#   none    — KMS disabled; ops requiring keys raise ConfigError.
#   local   — File-based, dev only. Reads keys from $A81_KMS_LOCAL_DIR.
#   qkey    — Day 2 (see below). Working but out-of-scope for current sprint.
#   aws_kms — Reserved.
#
# The Day 2 architectural plan is OS-level KMS integration (PKCS#11,
# kernel keyring, systemd credential, or a local Unix-socket shim).
# OneShot/qkey lives outside G.A8.1 in that model. New KMS work
# should target the OS-level path, not extend qkey.
A81_KMS_PROVIDER=none
A81_KMS_LOCAL_DIR=                # Used by 'local' provider only

# ── Ternary-Native LLM (M4 — Edge↔Edge) ──────────────────
# Scaffold only at this stage. Provider 'none' is the only valid value
# until the BitNet 2.5 / T5-validation tracks land.
#   none           — disabled (the only supported value today)
#   t5_validation  — T5 distilled on EH VSAs (validation precursor)
#   bitnet25       — BitNet 2.5 on EH VSAs (production target)
A81_LLM_PROVIDER=none
A81_LLM_ENDPOINT=                 # Resolved transport endpoint when provider != none
A81_LLM_ATTESTATION_REQUIRED=true # Require remote attestation of model hash before issuing queries

# ── Paths ────────────────────────────────────────────────
# Required for encode pipelines and query service.
# Override per deployment via environment or edit here directly.

# Source data — where the raw input files/directories live
A81_SOURCE_PATH=/Users/stark/Quantum_Computing_Lab/MjolnirPhotonics/product.edge.analyst.bsc/edge_service/staged

# Target output — where the encoded holographic matrix is written/read
A81_INDEX_PATH=/Users/stark/Quantum_Computing_Lab/OUT

# Product directory — contains hooks.py for query intelligence
A81_PRODUCT_DIR=/Users/stark/Quantum_Computing_Lab/MjolnirPhotonics/product.edge.analyst.bsc

# Media directory — where image/video files referenced by source data live
# Leave unset to auto-detect from source data parent
A81_MEDIA_DIR=

# Custom gazetteer file (optional — overrides product gazetteer)
A81_GAZETTEER_PATH=

# Clusters file — generated by discover_clusters.py, used by encode.py
A81_CLUSTERS_PATH=/Users/stark/Quantum_Computing_Lab/OUT/clusters.json

# ═══════════════════════════════════════════════════════════
#  Day 2 — out of scope for current sprint
#
#  Settings below are functional but are NOT part of the active
#  G.A8.1 deployment story. They will be replaced by an OS-level
#  KMS integration in a later sprint. Leaving them here so anyone
#  with an existing qkey deployment can still opt in via
#  A81_KMS_PROVIDER=qkey.
# ═══════════════════════════════════════════════════════════

# qkey provider settings — Day 2 (used when A81_KMS_PROVIDER=qkey).
A81_QKEY_URL=                     # https://host[:port]/qkey  (no trailing slash)
A81_QKEY_ACCESS_KEY=              # X-Access-Key header value (dev/inline; prefer FILE)
A81_QKEY_ACCESS_KEY_FILE=         # Path to file containing the access key (preferred)
A81_QKEY_MODE=omega               # omega | otp | quantum_noise | pqc | kem
A81_QKEY_TIMEOUT_SECONDS=10
A81_QKEY_VERIFY_TLS=true          # Set false ONLY in dev with self-signed certs
